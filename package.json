{
  "name": "demon-slayer-pixel",
  "version": "1.0.0",
  "description": "一个基于 React 19、Jotai、Tailwind CSS 与 TypeScript 的 2D 像素风生存小游戏。玩家扮演炭治郎，在不断刷新的小怪与阶段式 Boss 战中尽可能生存并提高分数。",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "compress": "node scripts/compress-assets.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "jotai": "^2.12.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.5",
    "tinify": "^1.8.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.21"
  }
}
